    {
      "text": "tante cose.",
      "start": 956.56,
      "duration": 6.8
    },
    {
      "text": "Quello che c'è di vero è solo che chi sa",
      "start": 959.16,
      "duration": 6.76
    },
    {
      "text": "giocare a calcio può giocare insieme a",
      "start": 963.36,
      "duration": 5.56
    },
    {
      "text": "chiunque. E se un allenatore è bravo a",
      "start": 965.92,
      "duration": 5.039
    },
    {
      "text": "mettere insieme",
      "start": 968.92,
      "duration": 4.76
    },
    {
      "text": "una formazione logica,",
      "start": 970.959,
      "duration": 6.12
    },
    {
      "text": "alla fine chi sta in campo",
      "start": 973.68,
      "duration": 6.44
    },
    {
      "text": "e sa dialogare con chi sa dare del tuo",
      "start": 977.079,
      "duration": 4.841
    },
    {
      "text": "alla palla,",
      "start": 980.12,
      "duration": 6.12
    },
    {
      "text": "trova sempre una soluzione buona.",
      "start": 981.92,
      "duration": 7.68
    },
    {
      "text": "Troppi schematismi, troppi tatticismi ci",
      "start": 986.24,
      "duration": 5.64
    },
    {
      "text": "hanno portato a un calcio che è una",
      "start": 989.6,
      "duration": 4.799
    },
    {
      "text": "sbobba inguardabile.",
      "start": 991.88,
      "duration": 4.16
    },
    {
      "text": "Godiamoci il calcio sotto un'altra",
      "start": 994.399,
      "duration": 2.88
    },
    {
      "text": "forma.",
      "start": 996.04,
      "duration": 2.88
    },
    {
      "text": "di lasciare libero l'estero dei",
      "start": 997.279,
      "duration": 4.841
    },
    {
      "text": "calciatori, qualora ancora ce ne sia in",
      "start": 998.92,
      "duration": 5.24
    },
    {
      "text": "giro",
      "start": 1002.12,
      "duration": 5.36
    },
    {
      "text": "e goderci anche le belle giocate perché",
      "start": 1004.16,
      "duration": 8.52
    },
    {
      "text": "il calcio fondamentalmente rimane arte.",
      "start": 1007.48,
      "duration": 6.88
    },
    {
      "text": "[Musica]",
      "start": 1012.68,
      "duration": 5.88
    },
    {
      "text": "Il punto chiaro di Umberto Chiariello.",
      "start": 1014.36,
      "duration": 4.2
    }
