    {
      "text": "Fiorentina non è una squadra, la",
      "start": 947.319,
      "duration": 3.281
    },
    {
      "text": "Fiorentina sta messa male, la Fiorentina",
      "start": 948.759,
      "duration": 3.361
    },
    {
      "text": "è un guaio, la Fiorentina è un disastro,",
      "start": 950.6,
      "duration": 3.2
    },
    {
      "text": "in difesa è un disastro.\" Sì, tutto",
      "start": 952.12,
      "duration": 4.24
    },
    {
      "text": "vero. Ma perché il Parma di questa che è",
      "start": 953.8,
      "duration": 5.2
    },
    {
      "text": "venuto qui senza Pellegrino, senza",
      "start": 956.36,
      "duration": 4.719
    },
    {
      "text": "Bernabé, senza il capitano, senza",
      "start": 959,
      "duration": 4.92
    },
    {
      "text": "l'altro terzino, senza il portiere, con",
      "start": 961.079,
      "duration": 4.44
    },
    {
      "text": "un esordiente di Serie C in porta,",
      "start": 963.92,
      "duration": 3.88
    },
    {
      "text": "eccetera eccetera che ha fatto, non si è",
      "start": 965.519,
      "duration": 5.521
    },
    {
      "text": "portato a casa lo 0-0.",
      "start": 967.8,
      "duration": 5.039
    },
    {
      "text": "Quindi non date per scontato per niente.",
      "start": 971.04,
      "duration": 4.32
    },
    {
      "text": "Questa vittoria non è scontata, ma",
      "start": 972.839,
      "duration": 4.92
    },
    {
      "text": "proprio per niente. La squadra è",
      "start": 975.36,
      "duration": 4.719
    },
    {
      "text": "stanchissima, moralmente a pezzi perché",
      "start": 977.759,
      "duration": 4.2
    },
    {
      "text": "è uscita dalla Champions e questo è un",
      "start": 980.079,
      "duration": 4.801
    },
    {
      "text": "contraccolpo che c'è. Oggettivamente",
      "start": 981.959,
      "duration": 6.081
    },
    {
      "text": "c'è. Magari la trasformerà in rabbia.",
      "start": 984.88,
      "duration": 5.16
    },
    {
      "text": "Speriamo.",
      "start": 988.04,
      "duration": 5.56
    },
    {
      "text": "Speriamo, ma non abbiamo certezza.",
      "start": 990.04,
      "duration": 5.4
    },
    {
      "text": "E se poco la squadra ripete la",
      "start": 993.6,
      "duration": 4.679
    },
    {
      "text": "partitaccia col Parma?",
      "start": 995.44,
      "duration": 4.879
    },
    {
      "text": "Oggi non escono tra gli applausi, ma",
      "start": 998.279,
      "duration": 5
    },
    {
      "text": "escono sonoramente fischiati",
      "start": 1000.319,
      "duration": 4.921
    },
    {
      "text": "e il Napoli si vede sul classato in",
      "start": 1003.279,
      "duration": 3.8
    },
    {
      "text": "classifica, esce fuori dalla zona",
      "start": 1005.24,
      "duration": 4.279
    },
    {
      "text": "Champions.",
      "start": 1007.079,
      "duration": 7.601
    },
    {
      "text": "Vincere oggi è la condizio sinequanon,",
      "start": 1009.519,
      "duration": 7.721
    },
    {
      "text": "ma è anche il minimo sindacale per",
      "start": 1014.68,
      "duration": 4.48
    },
    {
      "text": "restare a galla.",
      "start": 1017.24,
      "duration": 4.48
    },
    {
      "text": "E quando hai un peso così grosso e sei",
      "start": 1019.16,
      "duration": 6.2
    },
    {
      "text": "stanco e sei un po' demoralizzato",
      "start": 1021.72,
      "duration": 6.479
    },
    {
      "text": "non è mica facile.",
      "start": 1025.36,
      "duration": 5.36
    },
    {
      "text": "Ecco perché io dico,",
      "start": 1028.199,
      "duration": 4.64
    },
    {
      "text": "usiamo sempre tutti i luoghi comuni del",
      "start": 1030.72,
      "duration": 4.959
    },
    {
      "text": "mondo. Sono stufo di parlare di calcio",
      "start": 1032.839,
      "duration": 6.761
    },
    {
      "text": "per luoghi comuni, ma oggi",
      "start": 1035.679,
      "duration": 6.921
    },
    {
      "text": "un luogo comune che è la partita",
      "start": 1039.6,
      "duration": 4.839
    },
    {
      "text": "decisiva,",
      "start": 1042.6,
      "duration": 4.64
    },
    {
      "text": "non è solo un luogo comune, è una verità",
      "start": 1044.439,
      "duration": 4.681
    },
    {
      "text": "e una necessità.",
      "start": 1047.24,
      "duration": 5.92
    },
    {
      "text": "E quindi alle 18:00 alle 5 della tarda,",
      "start": 1049.12,
      "duration": 5.799
    },
    {
      "text": "diceva il poeta Garcia Lorca, noi",
      "start": 1053.16,
      "duration": 6.96
    },
    {
      "text": "diciamo alle 6:00 del pomeriggio,",
      "start": 1054.919,
      "duration": 5.201
    },
    {
      "text": "voglio rivedere gli stessi guerrieri che",
      "start": 1060.6,
      "duration": 5.4
    },
    {
      "text": "ho visto contro il Chelsea nel primo",
      "start": 1063.48,
      "duration": 6.36
    },
    {
      "text": "tempo per tutta la partita,",
      "start": 1066,
      "duration": 6.799
    },
    {
      "text": "perché questo Napoli, se ha la capacità",
      "start": 1069.84,
      "duration": 5.52
    },
    {
      "text": "di rialzarsi con i giovani che sta",
      "start": 1072.799,
      "duration": 4.561
    },
    {
      "text": "prendendo sul mercato che possono dare",
      "start": 1075.36,
      "duration": 4.28
    },
    {
      "text": "un contributo importante e con i",
      "start": 1077.36,
      "duration": 4.76
    },
    {
      "text": "recuperi necessari di giocatori",
      "start": 1079.64,
      "duration": 4.56
    },
    {
      "text": "fondamentali.",
      "start": 1082.12,
      "duration": 6.28
    },
    {
      "text": "Leggi Rakmani sa eppolitano su tutti,",
      "start": 1084.2,
      "duration": 7.12
    },
    {
      "text": "ma anche Gilmour. Non voglio parlare di",
      "start": 1088.4,
      "duration": 5.88
    },
    {
      "text": "De Bruin e Lukaku che deve tornare a una",
      "start": 1091.32,
      "duration": 5.88
    },
    {
      "text": "condizione accettabile. Tutto ciò in",
      "start": 1094.28,
      "duration": 6.2
    },
    {
      "text": "tempi medio brevi avverrà.",
      "start": 1097.2,
      "duration": 5.839
    },
    {
      "text": "Il Napoli che non crolla sotto i fischi",
      "start": 1100.48,
      "duration": 7.12
    },
    {
      "text": "dei tifosi e che non entra in crisi,",
      "start": 1103.039,
      "duration": 9.76
    },
    {
      "text": "ha tutto per chiudere la stagione bene,",
      "start": 1107.6,
      "duration": 9.6
    },
    {
      "text": "magari con secondo barra terzo posto,",
      "start": 1112.799,
      "duration": 6.961
    },
    {
      "text": "con finale di stagione convincente,",
      "start": 1117.2,
      "duration": 5.4
    },
    {
      "text": "anche con una buona Coppa Italia,",
      "start": 1119.76,
      "duration": 6.039
    },
    {
      "text": "lenirebbe l'amarezza della Champions che",
      "start": 1122.6,
      "duration": 5.8
    },
    {
      "text": "resterà come macchia pesante sulla",
      "start": 1125.799,
      "duration": 4.88
    },
    {
      "text": "stagione del Napoli.",
      "start": 1128.4,
      "duration": 4.88
    },
    {
      "text": "pesantissima,",
      "start": 1130.679,
      "duration": 4.441
    },
    {
      "text": "non cancellabile,",
      "start": 1133.28,
      "duration": 4.24
    },
    {
      "text": "non c'è tintoria che possa smacchiare",
      "start": 1135.12,
      "duration": 5
    },
    {
      "text": "questa macchia sulla maglia della",
      "start": 1137.52,
      "duration": 5.36
    },
    {
      "text": "stagione del Napoli. È inutile che ci",
      "start": 1140.12,
      "duration": 5.919
    },
    {
      "text": "proviate sminuendo la portata di quello",
      "start": 1142.88,
      "duration": 5.64
    },
    {
      "text": "che è accaduto",
      "start": 1146.039,
      "duration": 4.76
    },
    {
      "text": "e Conte dovrà fare una riflessione seria",
      "start": 1148.52,
      "duration": 6.32
    },
    {
      "text": "su tutto ciò. non può trincerarsi dietro",
      "start": 1150.799,
      "duration": 7.401
    },
    {
      "text": "gli infortuni. In campionato ha ragione.",
      "start": 1154.84,
      "duration": 5.28
    },
    {
      "text": "Col Chelsea, nel caso specifico aveva",
      "start": 1158.2,
      "duration": 5.32
    },
    {
      "text": "ragione, ma per l'andamento di coppa non",
      "start": 1160.12,
      "duration": 6.88
    },
    {
      "text": "può avere ragione e deve recitare prima",
      "start": 1163.52,
      "duration": 5.24
    },
    {
      "text": "degli altri, mettendosi in testa al",
      "start": 1167,
      "duration": 4.52
    },
    {
      "text": "gruppo, il me culpa.",
      "start": 1168.76,
      "duration": 5.08
    },
    {
      "text": "Lo perdoneremo perché con Conte vogliamo",
      "start": 1171.52,
      "duration": 5.44
    },
    {
      "text": "restare per anni perché ci garantisce",
      "start": 1173.84,
      "duration": 5
    },
    {
      "text": "determinazione, competitività e",
      "start": 1176.96,
      "duration": 4.36
    },
    {
      "text": "mentalità vincenti. Ma non basta in",
      "start": 1178.84,
      "duration": 5.199
    },
    {
      "text": "Italia, non vogliamo più essere solo",
      "start": 1181.32,
      "duration": 5.92
    },
    {
      "text": "indigeni. Ci vogliamo aprire all'Europa",
      "start": 1184.039,
      "duration": 6.441
    },
    {
      "text": "ed è il momento per tornare ad essere",
      "start": 1187.24,
      "duration": 5.76
    },
    {
      "text": "una squadra di rango europeo. Per",
      "start": 1190.48,
      "duration": 6.28
    },
    {
      "text": "arrivarci dobbiamo qualificarci e quindi",
      "start": 1193,
      "duration": 6.32
    },
    {
      "text": "Napoli- Fiorentina è un viatico",
      "start": 1196.76,
      "duration": 5.56
    },
    {
      "text": "fondamentale.",
      "start": 1199.32,
      "duration": 3
    }
