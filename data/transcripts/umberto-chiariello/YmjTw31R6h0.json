      "text": "un suo giocatore",
      "start": 590.72,
      "duration": 6.2
    },
    {
      "text": "che a suo dire è stato colpevolmente",
      "start": 593.6,
      "duration": 5.359
    },
    {
      "text": "trascurato nei mesi scorsi da un",
      "start": 596.92,
