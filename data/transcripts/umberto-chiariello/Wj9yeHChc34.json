    {
      "text": "l'141",
      "start": 553.959,
      "duration": 5.801
    },
    {
      "text": "si conta anche il portiere.",
      "start": 556.519,
      "duration": 5.961
    },
    {
      "text": "Questo è il modo di giocare in 10. Due",
      "start": 559.76,
      "duration": 5.36
    },
    {
      "text": "linee da quattro,",
      "start": 562.48,
      "duration": 6.359
    },
    {
      "text": "lo sanno anche i bambini.",
      "start": 565.12,
      "duration": 3.719
    },
    {
      "text": "4-1.",
      "start": 570.079,
      "duration": 3.0
    },
    {
      "text": "Mancini scende tra i centrocampisti,",
      "start": 573.279,
      "duration": 6.601
    },
    {
      "text": "fa da elastico con Casiraghi. La Lazio",
      "start": 576.6,
      "duration": 6.64
    },
    {
      "text": "non rinuncia a giocare",
      "start": 579.88,
      "duration": 5.8
    },
    {
      "text": "contro una squadra in quel momento inà",
      "start": 583.24,
      "duration": 5.88
    },
    {
      "text": "numerica più forte.",
      "start": 585.68,
      "duration": 5.399
    },
    {
      "text": "Sapete che succede? Che Mancini, quello",
      "start": 589.12,
      "duration": 4.56
    },
    {
      "text": "che non è uscito, è chi ha detto al",
      "start": 591.079,
      "duration": 4.76
    },
    {
      "text": "mister, mister, giochiamocela, non ci",
      "start": 593.68,
      "duration": 4.04
    },
    {
      "text": "chiudiamo in difesa, non togliere un",
      "start": 595.839,
      "duration": 5.321
    },
    {
      "text": "attaccante, giochiamocela.",
      "start": 597.72,
      "duration": 4.88
    },
    {
      "text": "Mancini, quello che ci ha fatto vincere",
      "start": 601.16,
      "duration": 3.52
    },
    {
      "text": "l'Europeo, lui quello che se la giocava",
      "start": 602.6,
      "duration": 4.84
    },
    {
      "text": "con tutti, lui l'unico che ci ha dato",
      "start": 604.68,
      "duration": 4.12
    },
    {
      "text": "una mentalità vincente negli ultimi",
      "start": 607.44,
      "duration": 3.44
    },
    {
      "text": "anni, quello che abbiamo mandato via a",
      "start": 608.8,
      "duration": 6.08
    },
    {
      "text": "calci come se fosse un reieto.",
      "start": 610.88,
      "duration": 6.079
    },
    {
      "text": "Ma in realtà Gravina l'aveva sfiduciato",
      "start": 614.88,
      "duration": 5.0
    },
    {
      "text": "lui. Mancini, nomo intelligente, grande",
      "start": 616.959,
      "duration": 4.601
    },
    {
      "text": "calciatore,",
      "start": 619.88,
      "duration": 4.199
    },
    {
      "text": "parte dalla metà campo,",
      "start": 621.56,
      "duration": 4.24
    },
    {
      "text": "si incunia all'inizio del secondo tempo",
      "start": 624.079,
      "duration": 4.641
    },
    {
      "text": "nella difesa del Roma e segna un gol",
      "start": 625.8,
      "duration": 5.92
    },
    {
      "text": "spettacolare.",
      "start": 628.72,
      "duration": 3.0
    },
    {
      "text": "La Roma accusa il colpo, si butta",
      "start": 632.519,
      "duration": 3.401
    },
    {
      "text": "avanti.",
      "start": 634.399,
      "duration": 4.801
    },
    {
      "text": "La Lazio non si chiude,",
      "start": 635.92,
      "duration": 7.0
    },
    {
      "text": "ribatte colpo su colpo, fa il 2-0 e fa",
      "start": 639.2,
      "duration": 8.36
    },
    {
      "text": "il 3-0. La partita finisce 3-1.",
      "start": 642.92,
      "duration": 6.719
    },
    {
      "text": "Nelle dichiarazioni dopo partita,",
      "start": 647.56,
      "duration": 6.24
    },
    {
      "text": "Mancini, il vero capo della Lazio, dice:",
      "start": 649.639,
      "duration": 6.721
    },
    {
      "text": "\"Non abbiamo avuto paura, ce la siamo",
      "start": 653.8,
      "duration": 4.52
    },
    {
      "text": "giocata,",
      "start": 656.36,
      "duration": 4.12
    },
    {
      "text": "ci siamo distribuiti i compiti. Ora,",
      "start": 658.32,
      "duration": 5.84
    },
    {
      "text": "ieri che doveva fare Gattuso?",
      "start": 660.48,
      "duration": 5.599
    },
    {
      "text": "Doveva aspettare la fine del primo",
      "start": 664.16,
      "duration": 3.64
    },
    {
      "text": "tempo, mancavano pochi minuti, non",
      "start": 666.079,
      "duration": 4.0
    },
    {
      "text": "doveva cambiare nessuno,",
      "start": 667.8,
      "duration": 3.96
    },
    {
      "text": "tanto lui giocava con tre i difensori",
      "start": 670.079,
      "duration": 3.641
    },
    {
      "text": "centrali. Qual era il problema se esce",
      "start": 671.76,
      "duration": 3.68
    },
    {
      "text": "bastone?",
      "start": 673.72,
      "duration": 4.919
    },
    {
      "text": "E poi doveva rimodulare la squadra.",
      "start": 675.44,
      "duration": 6.12
    },
    {
      "text": "Palestra a destra che è un treno,",
      "start": 678.639,
      "duration": 5.401
    },
    {
      "text": "un treno vero.",
      "start": 681.56,
      "duration": 4.76
    },
    {
      "text": "Calafiori e Di Marco a sinistra a fare",
      "start": 684.04,
      "duration": 5.039
    },
    {
      "text": "la cerniera, la cerniera tutti e due,",
      "start": 686.32,
      "duration": 4.56
    },
    {
      "text": "perché Calafiori nell'Arsenal gioca",
      "start": 689.079,
      "duration": 4.401
    },
    {
      "text": "terzino sinistro,",
      "start": 690.88,
      "duration": 5.72
    },
    {
      "text": "non centrale di difesa",
      "start": 693.48,
      "duration": 4.88
    },
    {
      "text": "e Di Marco è quello che ti poteva dare",
      "start": 696.6,
      "duration": 4.44
    },
    {
      "text": "qualcosa in avanti.",
      "start": 698.36,
      "duration": 6.12
    },
    {
      "text": "Chenna a scappare",
      "start": 701.04,
      "duration": 3.44
    },
    {
      "text": "i centrocampisti",
      "start": 705.2,
      "duration": 7.56
    },
    {
      "text": "a proporre Tonali e Barella",
      "start": 708.04,
      "duration": 4.72
    },
    {
      "text": "avrebbe potuto fare tranquillamente un",
      "start": 712.959,
      "duration": 6.0
    },
    {
      "text": "4-41.",
      "start": 715.959,
      "duration": 3.0
    },
    {
      "text": "4-4-1. Giocandosela",
      "start": 719.76,
      "duration": 4.44
    },
    {
      "text": "eravamo più forti, eravamo in vantaggio,",
      "start": 724.279,
      "duration": 7.56
    },
    {
      "text": "non abbassandosi a blocco basso,",
      "start": 728.88,
      "duration": 6.399
    },
    {
      "text": "accettando che dalle fasce piovessero",
      "start": 731.839,
      "duration": 7.0
    },
    {
      "text": "40.000 traversoni, prima o poi lo paghi",
      "start": 735.279,
      "duration": 6.441
    },
    {
      "text": "questo atteggiamento,",
      "start": 738.839,
      "duration": 5.8
    },
    {
      "text": "il solito pavido Gattuso. E poi fai",
      "start": 741.72,
      "duration": 5.559
    },
    {
      "text": "entrare Frattesi",
      "start": 744.639,
      "duration": 5.481
    },
    {
      "text": "e Cristante. Che cavolo c'entrano sti",
      "start": 747.279,
      "duration": 5.0
    },
    {
      "text": "due con la nazionale italiana? Chi",
      "start": 750.12,
      "duration": 4.2
    },
    {
      "text": "c'entrano?",
      "start": 752.279,
      "duration": 4.641
    },
    {
      "text": "Almeno Pisilli argento vivo, è uno che",
      "start": 754.32,
      "duration": 4.6
    },
    {
      "text": "gioca.",
      "start": 756.92,
      "duration": 3.479
    },
    {
      "text": "Se proprio vuoi cambiare Barella che",
      "start": 758.92,
      "duration": 5.279
    },
    {
      "text": "stava facendo pure bene,",
      "start": 760.399,
      "duration": 6.081
    },
    {
      "text": "non ha senso alcuno né le convocazioni",
      "start": 764.199,
      "duration": 5.361
    },
    {
      "text": "nelle scelte in campo e durante la",
      "start": 766.48,
      "duration": 4.719
    },
    {
      "text": "partita,",
      "start": 769.56,
      "duration": 3.519
    },
    {
      "text": "ma in fin dei conti è la risultante di",
      "start": 771.199,
      "duration": 4.32
    },
    {
      "text": "quella che è oggi la gestione, perché se",
      "start": 773.079,
      "duration": 4.44
    },
    {
      "text": "tu metti Gattuso te lo devi aspettare",
      "start": 775.519,
      "duration": 3.68
    },
    {
      "text": "che se c'è un momento di difficoltà",
      "start": 777.519,
      "duration": 6.281
    },
    {
      "text": "Gattuso tende a spaventarsi.",
      "start": 779.199,
      "duration": 7.121
    },
    {
      "text": "Gattuso era un mediano che correva per",
      "start": 783.8,
      "duration": 6.96
    },
    {
      "text": "tre. Meraviglioso, generoso,",
      "start": 786.32,
      "duration": 4.44
    },
    {
      "text": "ma era anche quello che nello",
      "start": 790.88,
      "duration": 3.24
    },
    {
      "text": "spogliatoio prendevano tutti in giro",
      "start": 792.279,
      "duration": 3.961
    },
    {
      "text": "perché era rozzo.",
      "start": 794.12,
      "duration": 5.839
    },
    {
      "text": "Pirlo lo faceva martire,",
      "start": 796.24,
      "duration": 6.959
    },
    {
      "text": "lo sanno tutti, è noto.",
      "start": 799.959,
      "duration": 5.281
    },
    {
      "text": "Può mai essere il leader un",
      "start": 803.199,
      "duration": 4.241
    },
    {
      "text": "portaborracce",
      "start": 805.24,
      "duration": 4.32
    },
    {
      "text": "meraviglioso come Gattuso. Porta",
      "start": 807.44,
      "duration": 5.68
    },
    {
      "text": "borracce meraviglioso come Gattuso. Che",
      "start": 809.56,
      "duration": 5.44
    },
    {
      "text": "sia chiaro, io la storia del Gattuso",
      "start": 813.12,
      "duration": 5.2
    },
    {
      "text": "calciatore. Chap.",
      "start": 815.0,
      "duration": 3.32
    },
    {
      "text": "Ma che tecnico è? Perché chiamare",
      "start": 818.36,
      "duration": 4.12
    },
    {
      "text": "Gattuso?",
      "start": 820.8,
      "duration": 3.479
    },
    {
      "text": "Perché devo vedere sulla panchina",
      "start": 822.48,
      "duration": 6.28
    },
    {
      "text": "Bonucci, Buffon e Gattuso.",
      "start": 824.279,
      "duration": 4.481
    },
    {
      "text": "Io avrei voluto vedere un allenatore",
      "start": 829.68,
      "duration": 4.12
    },
    {
      "text": "vero",
      "start": 831.0,
      "duration": 4.8
    },
    {
      "text": "che costruiva una nazionale vera come fu",
      "start": 833.8,
      "duration": 5.2
    },
    {
      "text": "la nazionale di Mancini con Bialli alle",
      "start": 835.8,
      "duration": 8.12
    },
    {
      "text": "spalle, altro allenatore vero.",
      "start": 839.0,
      "duration": 4.92
    },
    {
      "text": "Siamo usciti con la Bosnia dopo la",
      "start": 844.56,
      "duration": 5.16
    },
    {
      "text": "Macedonia e Gravina sta aggrappato alla",
      "start": 846.839,
      "duration": 5.881
    },
    {
      "text": "poltrona. Ma cosa ti aggrappi?",
      "start": 849.72,
      "duration": 7.28
    },
    {
      "text": "Devi andare a casa come la Santaché.",
      "start": 852.72,
      "duration": 4.28
    },
    {
      "text": "Sei un disastro.",
      "start": 857.48,
      "duration": 4.44
    },
    {
      "text": "La tua gestione è disastrosa. Sei stato",
      "start": 859.72,
      "duration": 4.52
    },
    {
      "text": "eletto al 98% dei voti perché non dai",
      "start": 861.92,
      "duration": 6.599
    },
    {
      "text": "fastidio a nessuno, non conti niente,",
      "start": 864.24,
      "duration": 8.12
    },
    {
      "text": "hai fatto una sola cosa,",
      "start": 868.519,
      "duration": 3.841
    },
    {
      "text": "ti sei alzato lo stipendio.",
      "start": 872.839,
      "duration": 3.761
    },
    {
      "text": "Boh, per te.",
      "start": 877.36,
      "duration": 5.52
    },
    {
      "text": "Devi andare a casa",
      "start": 879.92,
      "duration": 5.52
    },
    {
      "text": "tu e tutto il tuo staff.",
      "start": 882.88,
      "duration": 6.28
    },
    {
      "text": "A B devi azzerare questi vertici,",
      "start": 885.44,
      "duration": 6.04
    },
    {
      "text": "bisogna ripartire. Ma perché Ancelotti",
      "start": 889.16,
      "duration": 5.08
    },
    {
      "text": "deve andare ad allenare fuori Italia e",
      "start": 891.48,
      "duration": 4.88
    },
    {
      "text": "non in Italia?",
      "start": 894.24,
      "duration": 6.519
    },
    {
      "text": "Perché Ragieri rifiuta la nazionale?",
      "start": 896.36,
      "duration": 4.399
    },
    {
      "text": "Perché oggi la nazionale è un punto così",
      "start": 901.199,
      "duration": 4.921
    },
    {
      "text": "basso?",
      "start": 904.079,
      "duration": 4.12
    },
    {
      "text": "e tutto il movimento italiano che ne",
      "start": 906.12,
      "duration": 5.68
    },
    {
      "text": "perde totalmente.",
      "start": 908.199,
      "duration": 3.601
    },
    {
      "text": "Ieri l'Italia è stata allo specchio di",
      "start": 912.279,
      "duration": 6.521
    },
    {
      "text": "quello che è oggi",
      "start": 915.12,
      "duration": 6.719
    },
    {
      "text": "il sistema italiano",
      "start": 918.8,
      "duration": 8.279
    },
    {
      "text": "calcistico, per non parlare del resto.",
      "start": 921.839,
      "duration": 5.24
    },
    {
      "text": "È un sistema pavido,",
      "start": 927.279,
      "duration": 5.321
    },
    {
      "text": "povero.",
      "start": 930.24,
      "duration": 5.88
    },
    {
      "text": "Non eravamo scarsi, non siamo scarsi,",
      "start": 932.6,
      "duration": 6.76
    },
    {
      "text": "siamo malgestiti,",
      "start": 936.12,
      "duration": 5.32
    },
    {
      "text": "non abbiamo trovato lo spazio neanche",
      "start": 939.36,
      "duration": 6.839
    },
    {
      "text": "per fare uno stage e non c'era.",
      "start": 941.44,
      "duration": 7.6
    },
    {
      "text": "Poi vogliamo che andiamo ai mondiali.",
      "start": 946.199,
      "duration": 6.841
    },
    {
      "text": "E se De Laurentis dice",
      "start": 949.04,
      "duration": 7.32
    },
    {
      "text": "bisogna riformare tutto ripartendo da",
      "start": 953.04,
      "duration": 6.88
    },
    {
      "text": "zero, mettendo un uomo di provata",
      "start": 956.36,
      "duration": 5.839
    },
    {
      "text": "capacità ed esperienza e carisma come",
      "start": 959.92,
      "duration": 5.159
    },
    {
      "text": "Malagò e soprattutto",
      "start": 962.199,
      "duration": 5.32
    },
    {
      "text": "riformare il sistema diminuendo il",
      "start": 965.079,
      "duration": 6.2
    },
    {
      "text": "numero di partite e risarcendo i club.",
      "start": 967.519,
      "duration": 5.521
    },
    {
      "text": "Il giusto perché ti forniscono i",
      "start": 971.279,
      "duration": 3.36
    },
    {
      "text": "calciatori",
      "start": 973.04,
      "duration": 3.799
    },
    {
      "text": "non dice una sciocchezza, non la dice",
      "start": 974.639,
      "duration": 4.961
    },
    {
      "text": "affatto.",
      "start": 976.839,
      "duration": 5.081
    },
    {
      "text": "E sono oltre 20 anni che è nel calcio.",
      "start": 979.6,
      "duration": 3.88
    },
    {
      "text": "Non si può dire che oggi non sappia come",
      "start": 981.92,
      "duration": 4.599
    },
    {
      "text": "vadano le cose nel calcio.",
      "start": 983.48,
      "duration": 7.08
    },
    {
      "text": "Abamo una barca in mezzo ai marosi",
      "start": 986.519,
      "duration": 6.44
    },
    {
      "text": "e io so solo una cosa che il mio povero",
      "start": 990.56,
      "duration": 4.639
    },
    {
      "text": "figliolo",
      "start": 992.959,
      "duration": 5.68
    },
    {
      "text": "nato nel 2003",
      "start": 995.199,
      "duration": 7.361
    },
    {
      "text": "non ha mai visto con corricordi o",
      "start": 998.639,
      "duration": 6.68
    },
    {
      "text": "cognizioni di causa.",
      "start": 1002.56,
      "duration": 6.279
    },
    {
      "text": "Forse quello del 2014",
      "start": 1005.319,
      "duration": 5.08
    },
    {
      "text": "aveva",
      "start": 1008.839,
      "duration": 4.56
    },
    {
      "text": "11 anni, se lo ricorderà.",
      "start": 1010.399,
      "duration": 5.24
    },
    {
      "text": "Quello del 2010 aveva 7 anni, non se lo",
      "start": 1013.399,
      "duration": 4.841
    },
    {
      "text": "ricorderà. La pittoria del 2006 aveva 3",
      "start": 1015.639,
      "duration": 4.2
    },
    {
      "text": "anni, manco sapeva che esisteva il",
      "start": 1018.24,
      "duration": 4.24
    },
    {
      "text": "calcio.",
      "start": 1019.839,
      "duration": 8.321
    },
    {
      "text": "Non ha mai visto l'Italia ai mondiali.",
      "start": 1022.48,
      "duration": 5.68
    },
    {
      "text": "Mi dispiace Francesco,",
      "start": 1028.28,
      "duration": 3.759
    },
    {
      "text": "mi dispiace.",
      "start": 1032.679,
      "duration": 5.0
    },
    {
      "text": "Giorgio,",
      "start": 1035.4,
      "duration": 5.519
    },
    {
      "text": "mi dispiace.",
      "start": 1037.679,
      "duration": 3.24
    },
    {
      "text": "Massimo, Nicola, Pasquale,",
      "start": 1041.559,
      "duration": 5.52
    },
    {
      "text": "tutti i ragazzi",
      "start": 1045.12,
      "duration": 4.4
    },
    {
      "text": "di quella generazione",
      "start": 1047.079,
      "duration": 4.121
    },
    {
      "text": "Z",
      "start": 1049.52,
      "duration": 4.2
    },
    {
      "text": "che non sanno cos'è l'emozione di un",
      "start": 1051.2,
      "duration": 6.16
    },
    {
      "text": "mondiale di calcio, non hanno pianto a",
      "start": 1053.72,
      "duration": 6.76
    },
    {
      "text": "Italia-Germania 4-3, a Italia-Brasile",
      "start": 1057.36,
      "duration": 8.08
    },
    {
      "text": "3-2, a Italia-Argentina 2-1.",
      "start": 1060.48,
      "duration": 9.6
    },
    {
      "text": "a Italia-Fancia, a Italia-Germania",
      "start": 1065.44,
      "duration": 4.64
    },
    {
      "text": "e anche nelle sconfitte",
      "start": 1070.52,
      "duration": 6.32
    },
    {
      "text": "loro queste emozioni",
      "start": 1074.28,
      "duration": 6.48
    },
    {
      "text": "non le hanno mai vissute.",
      "start": 1076.84,
      "duration": 8.76
    },
    {
      "text": "E quando se a Dio piacendo nel 2030",
      "start": 1080.76,
      "duration": 8.56
    },
    {
      "text": "forse parteciperemo al mondiale, forse,",
      "start": 1085.6,
      "duration": 6.6
    },
    {
      "text": "non c'è nessuna certezza,",
      "start": 1089.32,
      "duration": 6.719
    },
    {
      "text": "quei ragazzi del 2003, del 2000, del",
      "start": 1092.2,
      "duration": 6.4
    },
    {
      "text": "2001, del 2002",
      "start": 1096.039,
      "duration": 5.361
    },
    {
      "text": "saranno adulti,",
      "start": 1098.6,
      "duration": 4.64
    },
    {
      "text": "sposati,",
      "start": 1101.4,
      "duration": 6.0
    },
    {
      "text": "padri, madri",
      "start": 1103.24,
      "duration": 4.16
    },
    {
      "text": "e diranno",
      "start": 1107.72,
      "duration": 3.48
    },
    {
      "text": "il calcio",
      "start": 1109.76,
      "duration": 3.12
    },
    {
      "text": "I mondiali",
      "start": 1111.2,
      "duration": 3.44
    },
    {
      "text": "non conosco,",
      "start": 1112.88,
      "duration": 4.56
    },
    {
      "text": "non so cosa siano. Ah, sì, li ho visti",
      "start": 1114.64,
      "duration": 6.159
    },
    {
      "text": "dal divano, ma noi non c'eravamo.",
      "start": 1117.44,
      "duration": 5.16
    },
    {
      "text": "Le emozioni,",
      "start": 1120.799,
      "duration": 5.601
    },
    {
      "text": "Gigi, Riva, Mazzola, Rivera, Antognoni,",
      "start": 1122.6,
      "duration": 7.439
    },
    {
      "text": "Tardelli, l'urlo di Munk,",
      "start": 1126.4,
      "duration": 6.84
    },
    {
      "text": "loro sanno cosa significa.",
      "start": 1130.039,
      "duration": 5.401
    },
    {
      "text": "Loro ieri sera si sono fermati alle",
      "start": 1133.24,
      "duration": 5.72
    },
    {
      "text": "lacrime di Gattuso,",
      "start": 1135.44,
      "duration": 3.52
    },
    {
      "text": "che sono le lacrime di tutta l'Italia",
      "start": 1139.48,
      "duration": 8.76
    },
    {
      "text": "che si è affidata a un uomo Non.",
      "start": 1143.559,
      "duration": 4.681
    },
    {
      "text": "Perché loro non l'hanno vissuto e non lo",
      "start": 1164.84,
      "duration": 4.04
    },
    {
      "text": "vivranno",
      "start": 1167.039,
      "duration": 3.681
    },
    {
      "text": "e noi",
      "start": 1168.88,
      "duration": 4.96
    },
    {
      "text": "forse non ci saremo più per raccontare",
      "start": 1170.72,
      "duration": 5.72
    },
    {
      "text": "quelle incredibili emozioni quando",
      "start": 1173.84,
      "duration": 8.12
    },
    {
      "text": "Martellini gridava: \"Riva, riva, riva\"",
      "start": 1176.44,
      "duration": 8.68
    },
    {
      "text": "e l'Italia fa 3-2 alla Germania.",
      "start": 1181.96,
      "duration": 6.44
    },
    {
      "text": "o Rivera che fa il 4-3 o Paolo Rossi che",
      "start": 1185.12,
      "duration": 6.2
    },
    {
      "text": "fa la tripletta.",
      "start": 1188.4,
      "duration": 7.04
    },
    {
      "text": "Loro queste cose non le vedranno mai da",
      "start": 1191.32,
      "duration": 6.8
    },
    {
      "text": "adulti forse, ma gli abbiamo bruciato",
      "start": 1195.44,
      "duration": 6.16
    },
    {
      "text": "un'intera gioventù.",
      "start": 1198.12,
      "duration": 3.48
    },
    {
      "text": "Il punto chiaro di Umberto Chiariello.",
      "start": 1205.2,
      "duration": 5.52
    },
    {
      "text": ">> Alerod, allestimento di uffici, il",
      "start": 1208.64,
      "duration": 4.36
    },
    {
      "text": "partner di oggi per i tuoi successi di",
      "start": 1210.72,
      "duration": 3.92
    },
    {
      "text": "domani.",
      "start": 1213.0,
      "duration": 5.32
    },
    {
      "text": ">> New Ital Butter, l'arte del burro.",
      "start": 1214.64,
      "duration": 8.6
    },
    {
      "text": "Il burro come non lo avete mai visto.",
      "start": 1218.32,
      "duration": 4.92
    },
    {
      "text": ">> Dove la terra è generosa e il lavoro è",
      "start": 1223.28,
      "duration": 5.24
    },
    {
      "text": "fatto con rispetto, nasce un vino che",
      "start": 1226.039,
      "duration": 5.0
    },
    {
      "text": "racconta chi siamo.",
      "start": 1228.52,
      "duration": 5.639
    },
    {
      "text": "Cantina dei Quinti. Radici profonde,",
      "start": 1231.039,
      "duration": 5.681
    },
    {
      "text": "sguardo lontano. Ogni bottiglia è",
      "start": 1234.159,
      "duration": 5.921
    },
    {
      "text": "territorio, ogni sorso è identità.",
      "start": 1236.72,
      "duration": 5.88
    },
    {
      "text": "Cantina [musica] dei Quinti. Visita il",
      "start": 1240.08,
      "duration": 5.12
    },
    {
      "text": "sito www.cantinadeiquinti.",
      "start": 1242.6,
      "duration": 4.84
    },
    {
      "text": "It's",
      "start": 1245.2,
      "duration": 2.24
    }
