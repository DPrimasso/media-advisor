    {
      "text": "è anche venuto il momento che il",
      "start": 1020.839,
      "duration": 5.881
    },
    {
      "text": "confronto con la squadra sia franco e",
      "start": 1023.36,
      "duration": 6.079
    },
    {
      "text": "sotto anche i suoi occhi.",
      "start": 1026.72,
      "duration": 5.68
    },
    {
      "text": "Solo così se si mettono dalla stessa",
      "start": 1029.439,
      "duration": 6.76
    },
    {
      "text": "parte società, tecnico e staff e",
      "start": 1032.4,
      "duration": 5.48
    },
    {
      "text": "squadra,",
      "start": 1036.199,
      "duration": 5.36
    },
    {
      "text": "ci sono le forze, ci sono le risorse",
      "start": 1037.88,
      "duration": 5.48
    },
    {
      "text": "per rispondere a tutti i gufi del nord",
      "start": 1041.559,
      "duration": 4.12
    },
    {
      "text": "che stanno banchettando sulle nostre",
      "start": 1043.36,
      "duration": 5.24
    },
    {
      "text": "spoglie col piacere di qualche nostro",
      "start": 1045.679,
      "duration": 4.841
    },
    {
      "text": "opinionista non strano che dice che ci",
      "start": 1048.6,
      "duration": 4.04
    },
    {
      "text": "stanno compiatendo.",
      "start": 1050.52,
      "duration": 4.44
    },
    {
      "text": "Io non voglio la pietà di nessuno. Io",
      "start": 1052.64,
      "duration": 3.919
    },
    {
      "text": "gli voglio fare un mazzo così agli",
      "start": 1054.96,
      "duration": 4.32
    },
    {
      "text": "avversari, sportivamente parlando, senza",
      "start": 1056.559,
      "duration": 5.721
    },
    {
      "text": "pietà.",
      "start": 1059.28,
      "duration": 3
    },
    {
      "text": ">> Il punto chiaro di Umberto Chiariello.",
      "start": 1066.24,
      "duration": 4.559
    },
    {
      "text": "[musica]",
      "start": 1070.282,
      "duration": 2.757
    },
    {
      "text": ">> Ogni giorno lavoriamo per offrirti il",
      "start": 1070.799,
      "duration": 5.161
    },
    {
      "text": "meglio. Caseificio Fratelli Pezzullo, la",
      "start": 1073.039,
      "duration": 5.281
    },
    {
      "text": "mozzarella come una volta. Alerod,",
      "start": 1075.96,
      "duration": 4.52
    },
    {
      "text": "allestimento di uffici, il partner di",
      "start": 1078.32,
      "duration": 5.92
