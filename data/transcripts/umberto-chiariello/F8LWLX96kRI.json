      "text": "ma queste parole di Conte dette a",
      "start": 510.159,
      "duration": 5.44
    },
    {
      "text": "Bologna sono",
      "start": 512.719,
      "duration": 7.44
    },
    {
      "text": "su carta già scritte, le stesse, le",
      "start": 515.599,
      "duration": 9.561
    },
    {
      "text": "identiche nel libro dove dice dare",
      "start": 520.159,
      "duration": 8.001
    },
    {
      "text": "tutto.",
      "start": 525.16,
      "duration": 3
    },
    {
      "text": "E lui dice, \"Il nostro è un lavoro dove",
      "start": 528.68,
      "duration": 3.76
    },
    {
      "text": "c'è uno spazio enorme per il fallimento",
      "start": 530.16,
      "duration": 4.08
    },
    {
      "text": "lui",
      "start": 532.44,
      "duration": 5.92
    },
    {
      "text": "sa tutto questo",
      "start": 534.24,
      "duration": 6.64
    },
    {
      "text": "ed è pronto ad affrontarlo.",
      "start": 538.36,
      "duration": 4.28
    },
    {
      "text": "Quindi toglietevi dalla testa che",
      "start": 540.88,
      "duration": 4.399
    },
    {
      "text": "Antonio Conte",
      "start": 542.64,
      "duration": 5.199
    },
    {
      "text": "si è preparato il terreno per fuggire. È",
      "start": 545.279,
      "duration": 6.441
    },
    {
      "text": "una vulgata che ormai è datata.",
      "start": 547.839,
      "duration": 6.841
    },
    {
      "text": "Antonio Conte ha voluto",
      "start": 551.72,
      "duration": 4.48
    },
    {
      "text": "e me ne sono convinto andando a",
      "start": 554.68,
      "duration": 5.08
    },
    {
      "text": "rileggere il suo libro,",
      "start": 556.2,
      "duration": 6.48
    },
    {
      "text": "dare una scossa all'ambiente, ma forte,",
      "start": 559.76,
      "duration": 6
    },
    {
      "text": "proprio un elettroshock.",
      "start": 562.68,
      "duration": 6.279
    },
    {
      "text": "Per me ha esagerato,",
      "start": 565.76,
      "duration": 5.406
    },
    {
      "text": "per me è andato in plurispetizia,",
      "start": 568.959,
      "duration": 5.521
    },
    {
      "text": "[musica] è andato oltre,",
      "start": 571.166,
      "duration": 5.634
    },
    {
      "text": "però lo capiremo,",
      "start": 574.48,
      "duration": 6.12
    },
    {
      "text": "magari sarà servito, magari la squadra",
      "start": 576.8,
      "duration": 5.36
    },
    {
      "text": "sarà messa di fronte alle proprie",
      "start": 580.6,
      "duration": 3.239
    },
    {
      "text": "responsabilità",
      "start": 582.16,
      "duration": 3.239
    },
    {
      "text": "a maggior ragione. Le parole di",
      "start": 583.839,
      "duration": 3.281
    },
    {
      "text": "Giuffredi ci fanno dire che i giocatori",
      "start": 585.399,
      "duration": 3.44
    },
    {
      "text": "sono pronti a seguire conto e che non è",
      "start": 587.12,
      "duration": 3.399
    },
    {
      "text": "vero che c'è frizione tra loro e il",
      "start": 588.839,
      "duration": 3.601
    },
    {
      "text": "tecnico. E se quello che ha detto",
      "start": 590.519,
      "duration": 3.801
    },
    {
      "text": "Giffredi corrisponde a verità e non ho",
      "start": 592.44,
      "duration": 5.28
    },
    {
      "text": "nessun motivo di dubitare che sia vero,",
      "start": 594.32,
      "duration": 6.4
    },
    {
      "text": "allora quello che è stato a Bologna,",
      "start": 597.72,
      "duration": 6.559
    },
    {
      "text": "un momento scioccante per tutti,",
      "start": 600.72,
      "duration": 6.76
    },
    {
      "text": "potrebbe rivelarsi perfino un momento",
      "start": 604.279,
      "duration": 4.921
    },
    {
      "text": "fondante,",
      "start": 607.48,
      "duration": 3.52
    },
    {
      "text": "ma questo lo capiremo solo vivendo,",
      "start": 609.2,
      "duration": 5.12
    },
    {
      "text": "avrebbe detto Mogol con Battisti, perché",
      "start": 611,
      "duration": 7.399
    },
    {
      "text": "tanto tra poco Atalanta, Roma, Juventus",
      "start": 614.32,
      "duration": 7.959
    },
    {
      "text": "Crotus Xalta.",
      "start": 618.399,
      "duration": 3.88
    },
    {
      "text": "Il punto chiaro di Umberto Chiariello.",
      "start": 623,
      "duration": 6
    },
    {
      "text": ">> Ogni [musica] giorno lavoriamo per",
      "start": 627.399,
      "duration": 4.161
    },
    {
      "text": "offrirti il meglio. Caseificio Fratelli",
      "start": 629,
      "duration": 5.68
    },
    {
      "text": "Pezzullo, la mozzarella come una volta.",
      "start": 631.56,
      "duration": 5.2
    },
    {
      "text": "Alerod, allestimento di uffici, il",
      "start": 634.68,
      "duration": 4.399
    },
    {
      "text": "partner di oggi per i tuoi successi di",
      "start": 636.76,
      "duration": 4.36
    },
    {
      "text": "domani.",
      "start": 639.079,
      "duration": 4.793
    },
    {
      "text": "New Ital Butter, l'arte del burro.",
      "start": 641.12,
      "duration": 4.772
    },
    {
      "text": "[musica]",
      "start": 643.872,
      "duration": 2.02
    }
