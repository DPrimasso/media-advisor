{
  "name": "media-advisor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "python -m uvicorn server.api:app --host 0.0.0.0 --port 3002 --reload --reload-dir server --reload-dir src",
    "prepare-public": "node web/scripts/prepare-public.js",
    "dev:kill": "node scripts/dev-kill.mjs",
    "dev": "npm run dev:kill && concurrently -n s,w \"npm run server\" \"npm run dev:web\"",
    "dev:web": "npm run dev --prefix web"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
