{
  "name": "media-advisor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "transcript": "tsx src/cli-transcript.ts",
    "analyze": "tsx src/cli-analyze.ts",
    "run-list": "tsx src/cli-from-list.ts",
    "fetch-preview": "tsx src/cli-fetch-preview.ts",
    "server": "uvicorn server.api:app --host 0.0.0.0 --port 3001 --reload --reload-dir server --reload-dir src",
    "prepare-public": "node web/scripts/prepare-public.js",
    "dev": "concurrently -n s,w \"npm run server\" \"npm run dev:web\"",
    "dev:web": "npm run dev --prefix web",
    "build": "tsc"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.77.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
